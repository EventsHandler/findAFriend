type AuthPayload {
  token: String!
  user: User!
}

type Crate {
  chance: Float!
  id: ID!
  name: String!
  price: Int!
  rarity: RarityType!
  rarityDrops: [CrateRarityDrop!]
}

type CrateInventory {
  crate: Crate
  crateId: String!
  id: ID!
  quantity: Int!
  user: User
  userId: String!
}

type CrateRarityDrop {
  chance: Float!
  crate: Crate
  crateId: String!
  id: ID!
  rarity: RarityType!
}

type Item {
  id: ID!
  name: String!
  rarity: RarityType!
}

type ItemInventory {
  id: ID!
  item: Item
  itemId: String!
  quantity: Int!
  user: User
  userId: String!
}

type Location {
  id: ID!
  name: String!
  posx: Float!
  posy: Float!
}

type Mutation {
  addPoints(amount: Int!, userId: ID!): Boolean!
  buyCrate(crateId: ID!, quantity: Int!, userId: ID!): Boolean!
  joinRoom(locationId: ID!): User!
  leaveRoom: User!
  locations: [Location!]
  login(name: String!, password: String!): AuthPayload!
  openCrate(crateId: ID!, userId: ID!): Item!
  register(name: String!, password: String!): AuthPayload!
  updatePosition(lat: Float!, lng: Float!, locationId: ID!): User!
}

type Query {
  crate(id: ID!): Crate
  crates: [Crate!]!
  item(id: ID!): Item
  items: [Item!]!
  locationUsers(locationId: ID!): [User!]!
  locations: [Location!]!
  me: User
  userCrate(crateId: ID!, userId: ID!): CrateInventory!
  userCrates(userId: ID!): [CrateInventory!]!
  userItems(userId: ID!): [ItemInventory!]!
}

enum RarityType {
  COMMON
  EPIC
  LEGENDARY
}

type User {
  crateInventories: [CrateInventory!]
  id: ID!
  inventories: [ItemInventory!]
  locationId: ID
  name: String!
