type AuthPayload {
  token: String!
  user: User!
}

type Event {
  derived: String!
  id: ID!
  name: String!
}

type Location {
  id: ID!
  name: String!
  posx: Float!
  posy: Float!
}

type Mutation {
  createEvent(name: String!): Event!
  login(name: String!, password: String!): AuthPayload!
  register(name: String!, password: String!): AuthPayload!
}

type Query {
  events(filter: String): [Event!]!
  locations: [Location!]!
  me: User
}

type User {
  id: ID!
  name: String!
}
