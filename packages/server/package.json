{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "exports": {
    ".": "./src/index.ts"
  },
  "private": true,
  "scripts": {
    "dev": "tsx --env-file .env --watch src/index.ts",
    "postinstall": "prisma generate",
    "seed:locations": "tsx --env-file .env src/seedLocations.ts",
    "seed:missions": "tsx --env-file .env src/seedMissions.ts",
    "backfill:mission-kinds": "tsx --env-file .env src/backfillMissionKinds.ts",
    "migrate": "pnpm prisma migrate deploy",
    "build": "pkgroll build",
    "start": "prisma migrate deploy && node dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.10.0",
  "devDependencies": {
    "@tsconfig/node23": "^23.0.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.3",
    "prisma": "^6.7.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@prisma/client": "6.7.0",
    "bcryptjs": "^3.0.3",
    "graphql": "^16.11.0",
    "graphql-yoga": "^5.13.4",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.35.0",
    "pkgroll": "^2.27.0",
    "pusher": "^5.3.3"
  }
}