// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id   String @id @default(cuid(2))
  name String
}

model User {
  id               String           @id @default(cuid(2))
  name             String           @unique
  password         String
  inventories      ItemInventory[]
  crateInventories CrateInventory[]

  locationId String? // current joined location
  location   Location? @relation(fields: [locationId], references: [id])
  posx       Float?
  posy       Float?
  points Int @default(0)
}

model Location {
  id   String @id @default(cuid(2))
  name String
  posx Float
  posy Float

  users User[]
}

model Crate {
  id     String @id @default(cuid(2))
  name   String @unique
  rarity RarityType
  chance Float
  price Int @default(0)
  rarityDrops CrateRarityDrop[]

  inventories CrateInventory[]
}

model CrateRarityDrop {
  id String @id @default(cuid(2))

  crateId String
  rarity  RarityType

  chance Float // ex: 0.7, 0.25, 0.05

  crate Crate @relation(fields: [crateId], references: [id])

  @@unique([crateId, rarity])
}

model Item {
  id     String @id @default(cuid(2))
  name   String @unique   
  rarity RarityType

  inventories ItemInventory[]
}

model CrateInventory {
  id String @id @default(cuid(2))

  userId  String
  crateId String

  quantity Int @default(1)

  user  User  @relation(fields: [userId], references: [id])
  crate Crate @relation(fields: [crateId], references: [id])

  @@unique([userId, crateId])
  @@index([userId])
}

model ItemInventory {
  id String @id @default(cuid(2))

  userId String
  itemId String

  quantity Int @default(1)

  user User @relation(fields: [userId], references: [id])
  item Item @relation(fields: [itemId], references: [id])

  @@unique([userId, itemId])
  @@index([userId])
}

enum RarityType {
  COMMON
  EPIC
  LEGENDARY
}
