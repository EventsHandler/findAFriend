// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id   String @id @default(cuid(2))
  name String
}

model User {
  id               String           @id @default(cuid(2))
  name             String           @unique
  password         String
  xp               Int              @default(0)
  inventories      ItemInventory[]
  crateInventories CrateInventory[]
  userMissions     UserMission[]
  questCompletions QuestCompletion[]

  locationId String? // current joined location
  location   Location? @relation(fields: [locationId], references: [id])
  posx       Float?
  posy       Float?
  points Int @default(0)
}

model Location {
  id   String @id @default(cuid(2))
  name String
  posx Float
  posy Float
  tag  LocationTag @default(LANDMARK)

  users    User[]
  missions Mission[]
}

enum LocationTag {
  PARK
  RESTAURANT
  LANDMARK
}

model Mission {
  id             String @id @default(cuid(2))
  title          String
  description    String?
  rewardXp       Int
  targetProgress Int    @default(100)
  /// If true, completing the quest records history and starts a cooldown before it can be claimed again.
  repeatable     Boolean @default(false)
  /// Hours after completion until a repeatable quest can be claimed again (e.g. 24 = daily refresh).
  cooldownHours  Int     @default(24)

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])

  userMissions     UserMission[]
  questCompletions QuestCompletion[]

  @@unique([locationId, title])
}

model UserMission {
  id          String            @id @default(cuid(2))
  userId      String
  missionId   String
  progress    Int               @default(0)
  status      UserMissionStatus @default(ACTIVE)
  completedAt DateTime?
  /// When set on a completed repeatable quest, claim is allowed again after this time.
  lockedUntil DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId])
  @@index([userId])
}

model QuestCompletion {
  id          String   @id @default(cuid(2))
  userId      String
  missionId   String
  title       String
  rewardXp    Int
  completedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt(sort: Desc)])
  @@index([userId, missionId])
}

enum UserMissionStatus {
  ACTIVE
  COMPLETED
}

model Crate {
  id     String @id @default(cuid(2))
  name   String @unique
  rarity RarityType
  chance Float
  price Int @default(0)
  rarityDrops CrateRarityDrop[]

  inventories CrateInventory[]
}

model CrateRarityDrop {
  id String @id @default(cuid(2))

  crateId String
  rarity  RarityType

  chance Float // ex: 0.7, 0.25, 0.05

  crate Crate @relation(fields: [crateId], references: [id])

  @@unique([crateId, rarity])
}

model Item {
  id     String @id @default(cuid(2))
  name   String @unique   
  rarity RarityType

  inventories ItemInventory[]
}

model CrateInventory {
  id String @id @default(cuid(2))

  userId  String
  crateId String

  quantity Int @default(1)

  user  User  @relation(fields: [userId], references: [id])
  crate Crate @relation(fields: [crateId], references: [id])

  @@unique([userId, crateId])
  @@index([userId])
}

model ItemInventory {
  id String @id @default(cuid(2))

  userId String
  itemId String

  quantity Int @default(1)

  user User @relation(fields: [userId], references: [id])
  item Item @relation(fields: [itemId], references: [id])

  @@unique([userId, itemId])
  @@index([userId])
}

enum RarityType {
  COMMON
  EPIC
  LEGENDARY
}
