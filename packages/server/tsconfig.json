{
  "extends": "@tsconfig/node23/tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "lib": ["ESNext"],
    "rootDir": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "allowImportingTsExtensions": false,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": false,
    "outDir": "dist",
    "allowSyntheticDefaultImports": true,
    // "esModuleInterop": false,
    //The deprecation warning occurs because TypeScript 6.0 makes esModuleInterop default to true and deprecates setting it to false. 
    //This option will be hard-removed in TypeScript 7.0.
    "noUncheckedSideEffectImports": true
  },
  "include": ["src", "env.d.ts"]
}
